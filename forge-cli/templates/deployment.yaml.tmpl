apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{.AgentID}}
  labels:
    app: {{.AgentID}}
    forge.initializ.ai/version: "{{.Version}}"
    {{- if .EgressProfile}}
    forge.initializ.ai/egress-profile: "{{.EgressProfile}}"
    {{- end}}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{.AgentID}}
  template:
    metadata:
      labels:
        app: {{.AgentID}}
        {{- if .EgressProfile}}
        forge.initializ.ai/egress-profile: "{{.EgressProfile}}"
        {{- end}}
    spec:
      containers:
        - name: {{.AgentID}}
          image: {{.Runtime.Image}}
          {{- if .Runtime.Port}}
          ports:
            - containerPort: {{.Runtime.Port}}
          {{- end}}
          env:
            # Platform policy file path (issue #89 / FWS-5). The volume
            # mount below is optional; when no ConfigMap is present,
            # the agent reads this path, finds it missing, and starts
            # with no platform-policy constraints (pre-FWS-5 behavior).
            - name: FORGE_PLATFORM_POLICY
              value: /etc/forge/policy/platform-policy.yaml
            {{- range $key, $val := .Runtime.Env}}
            - name: {{$key}}
              value: "{{$val}}"
            {{- end}}
            {{- range .RequiredEnvVars}}
            - name: {{.}}
              valueFrom:
                secretKeyRef:
                  name: {{$.AgentID}}-secrets
                  key: {{.}}
            {{- end}}
            {{- range .OptionalEnvVars}}
            - name: {{.}}
              valueFrom:
                secretKeyRef:
                  name: {{$.AgentID}}-secrets
                  key: {{.}}
                  optional: true
            {{- end}}
          volumeMounts:
            # Platform policy ConfigMap mount (issue #89 / FWS-5). Mounted
            # readOnly. Operators (or platform deployers like initializ
            # Command, custom controllers, GitOps tooling) create the
            # `forge-platform-policy` ConfigMap with key `platform-policy.yaml`
            # to apply workspace-level egress / tool / model bounds.
            # See docs/security/platform-policy.md.
            - name: platform-policy
              mountPath: /etc/forge/policy
              readOnly: true
      volumes:
        # Optional ConfigMap. When absent, the agent starts with no
        # platform-policy constraints — same behavior as pre-FWS-5.
        # `optional: true` is load-bearing: without it, the pod would
        # fail to start when the ConfigMap doesn't exist, breaking
        # self-managed deployments that don't need workspace bounds.
        - name: platform-policy
          configMap:
            name: forge-platform-policy
            optional: true
