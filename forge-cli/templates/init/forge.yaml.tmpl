agent_id: {{.AgentID}}
version: 0.1.0
framework: {{.Framework}}
{{- if .Entrypoint}}
entrypoint: {{.Entrypoint}}
{{- end}}

model:
  provider: {{.ModelProvider}}
  name: {{.ModelName}}
  version: "latest"
{{- if .OrganizationID}}
  organization_id: {{.OrganizationID}}
{{- end}}
{{- if .Fallbacks}}
  fallbacks:
{{- range .Fallbacks}}
    - provider: {{.Provider}}
      name: {{.ModelName}}
{{- end}}
{{- end}}
{{- if .Tools}}

tools:
{{- range .Tools}}
  - name: {{.Name}}
    type: {{.Type}}
{{- end}}
{{- end}}
{{- if .Channels}}

channels:
{{- range .Channels}}
  - {{.}}
{{- end}}
{{- end}}
{{- if .BuiltinTools}}

builtin_tools:
{{- range .BuiltinTools}}
  - {{.}}
{{- end}}
{{- end}}
{{- if .EgressDomains}}

egress:
  mode: allowlist
  allowed_domains:
{{- range .EgressDomains}}
    - {{.}}
{{- end}}
{{- end}}

secrets:
  providers:
{{- if .HasSecrets}}
    - encrypted-file
{{- end}}
    - env

scheduler:
  # Use the in-process file scheduler by default. The "auto" default would
  # pick the Kubernetes CronJob backend when running in-cluster, which
  # requires scheduler.kubernetes.service_url. Switch to backend: kubernetes
  # (and set kubernetes.service_url) when you want durable CronJob scheduling.
  backend: file

{{- if .AuthBlock}}

{{.AuthBlock}}
{{- end}}
