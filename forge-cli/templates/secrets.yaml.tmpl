apiVersion: v1
kind: Secret
metadata:
  name: {{.AgentID}}-secrets
  labels:
    app: {{.AgentID}}
  {{- if or .RequiredEnvVars .OptionalEnvVars}}
  annotations:
    forge.initializ.ai/generated: "true"
  {{- end}}
type: Opaque
stringData:
{{- range .RequiredEnvVars}}
  {{.}}: ""
{{- end}}
{{- range .OptionalEnvVars}}
  # optional
  {{.}}: ""
{{- end}}
{{- if not (or .RequiredEnvVars .OptionalEnvVars)}}
  # No env vars discovered from skills; add your secrets here.
  # EXAMPLE_KEY: ""
{{- end}}
